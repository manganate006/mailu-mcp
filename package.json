{
  "name": "@manganate06/mailu-mcp",
  "version": "1.0.1",
  "description": "MCP server for the Mailu mail server admin REST API (domains, users, aliases, alternatives, relays)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mailu-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/bundle.js --banner:js=\"import { createRequire as __cr } from 'module'; const require = __cr(import.meta.url);\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node test/selftest.mjs",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "mailu",
    "mail",
    "email",
    "smtp",
    "imap"
  ],
  "author": "manganate006",
  "license": "MIT",
  "homepage": "https://github.com/manganate006/mailu-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manganate006/mailu-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/manganate006/mailu-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "axios": "^1.6.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.24.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ]
}
